# Required — tool will fail without these
SERPER_API_KEY=         # https://serper.dev — 2,500 free searches on signup
PDL_API_KEY=            # https://peopledatalabs.com — 100 free req/month
ANTHROPIC_API_KEY=      # https://console.anthropic.com — email generation + LinkedIn profile extraction

# Optional — signals score zero if missing
BUILTWITH_API_KEY=      # https://builtwith.com/api — free tier won't detect Yardi/RealPage/Entrata; paid plan required for tech stack signal
CENSUS_API_KEY=         # https://api.census.gov/data/key_signup.html — optional, rate limit is generous without one
